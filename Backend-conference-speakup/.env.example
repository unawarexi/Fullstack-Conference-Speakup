\# ─────────────────────────────────────────────────
# SpeakUp Backend — Environment Variables
# Copy to .env and fill in your values
# ─────────────────────────────────────────────────

# ──── APP ────
NODE_ENV=development
PORT=3000
API_VERSION=v1
APP_NAME=SpeakUp
APP_URL=http://localhost:3000
CORS_ORIGINS=http://localhost:3000,http://localhost:3001,http://localhost:5173

# ──── DATABASE (PostgreSQL) ────
DATABASE_URL=postgresql://user:password@localhost:5432/speakup?schema=public

# ──── REDIS ────
REDIS_URL=redis://localhost:6379
REDIS_PASSWORD=
REDIS_TLS=false

# ──── FIREBASE ADMIN ────
FIREBASE_SERVICE_ACCOUNT=    # Full JSON string in production (Render/K8s)

# ──── LIVEKIT (SFU Media Plane) ────
LIVEKIT_API_URL=http://localhost:7880
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=

# ──── KAFKA ────
KAFKA_BROKERS=localhost:9092
KAFKA_CLIENT_ID=speakup-api
KAFKA_GROUP_ID=speakup-consumers

# ──── BULLMQ ────
BULLMQ_REDIS_URL=redis://localhost:6379

# ──── AWS / S3 (Recordings & file uploads) ────
AWS_REGION=eu-west-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
S3_BUCKET_RECORDINGS=speakup-recordings
S3_BUCKET_UPLOADS=speakup-uploads

# ──── CLOUDINARY (Avatars & images) ────
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# ──── STRIPE (Billing) ────
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# ──── SMTP (Email) ────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM="SpeakUp <noreply@speakup.io>"

# ──── SENTRY (Error monitoring) ────
SENTRY_DSN=
SENTRY_ENVIRONMENT=development
SENTRY_TRACES_SAMPLE_RATE=0.2
SENTRY_PROFILES_SAMPLE_RATE=0.1

# ──── PROMETHEUS ────
PROMETHEUS_ENABLED=true

# ──── CLOUDFLARE ────
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_ZONE_ID=

# ──── WEBRTC TURN/STUN ────
TURN_SERVER_URL=
TURN_SERVER_USERNAME=
TURN_SERVER_PASSWORD=
STUN_SERVER_URL=stun:stun.l.google.com:19302

# ──── RATE LIMITING ────
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
AUTH_RATE_LIMIT_MAX=20

# ──── LOGGING ────
LOG_LEVEL=debug
