{
  "name": "backend-conference-speakup",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "start": "node index.js",
    "dev": "nodemon index.js",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "vitest",
    "test:run": "vitest run",
    "ci": "npm run lint && npm run test:run",
    "db:generate": "npx prisma generate",
    "db:push": "npx prisma db push",
    "db:migrate": "npx prisma migrate dev",
    "db:studio": "npx prisma studio",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.{js,mjs}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md,yml,yaml}": [
      "prettier --write"
    ]
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1025.0",
    "@aws-sdk/s3-request-presigner": "^3.1025.0",
    "@prisma/adapter-pg": "^7.6.0",
    "@prisma/client": "^7.6.0",
    "@sentry/node": "^10.47.0",
    "@sentry/profiling-node": "^10.47.0",
    "@socket.io/redis-adapter": "^8.3.0",
    "bullmq": "^5.71.1",
    "cloudinary": "^2.9.0",
    "compression": "^1.8.1",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.6",
    "dayjs": "^1.11.20",
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "express-rate-limit": "^8.3.2",
    "firebase-admin": "^13.0.0",
    "helmet": "^8.1.0",
    "ioredis": "^5.10.1",
    "kafkajs": "^2.2.4",
    "livekit-server-sdk": "^2.9.1",
    "morgan": "^1.10.1",
    "multer": "^2.1.1",
    "nodemailer": "^8.0.4",
    "nodemon": "^3.1.14",
    "pg": "^8.16.0",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "prisma": "^7.6.0",
    "prom-client": "^15.1.3",
    "rate-limiter-flexible": "^10.0.1",
    "socket.io": "^4.8.3",
    "stripe": "^17.7.0",
    "uuid": "^13.0.0",
    "winston": "^3.19.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.5.0",
    "@commitlint/config-conventional": "^20.5.0",
    "@eslint/js": "^10.0.1",
    "@stylistic/eslint-plugin-js": "^4.4.1",
    "eslint": "^10.1.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-n": "^17.24.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "prettier": "^3.8.1",
    "supertest": "^7.2.2",
    "vitest": "^4.1.2"
  },
  "trustedDependencies": [
    "@firebase/util",
    "@sentry-internal/node-cpu-profiler",
    "aws-sdk",
    "protobufjs"
  ]
}
