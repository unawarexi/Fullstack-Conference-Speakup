# ============================================================================
# SpeakUp AI — Environment Configuration
# Copy to .env and fill in your values
# ============================================================================

# ── Application ──
APP_NAME=speakup-ai
APP_ENV=development
DEBUG=true
LOG_LEVEL=INFO
API_V1_PREFIX=/api/v1
SECRET_KEY=change-me-to-a-random-64-char-string
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5000

# ── Server ──
HOST=0.0.0.0
PORT=8000
WORKERS=4
RELOAD=true

# ── PostgreSQL ──
DATABASE_URL=postgresql+asyncpg://speakup:speakup_dev@localhost:5432/speakup_ai
DATABASE_POOL_SIZE=20
DATABASE_MAX_OVERFLOW=10

# ── Redis ──
REDIS_URL=redis://localhost:6379/1
REDIS_MAX_CONNECTIONS=50

# ── Kafka ──
KAFKA_BROKERS=localhost:9092
KAFKA_CLIENT_ID=speakup-ai
KAFKA_GROUP_ID=speakup-ai-consumers
KAFKA_SSL=false
KAFKA_SASL_USERNAME=
KAFKA_SASL_PASSWORD=

# ── Qdrant (Vector DB) ──
QDRANT_HOST=localhost
QDRANT_PORT=6333
QDRANT_API_KEY=
QDRANT_COLLECTION_MEETINGS=meeting_memories
QDRANT_COLLECTION_KNOWLEDGE=knowledge_base

# ── Neo4j (Graph DB) ──
NEO4J_URI=bolt://localhost:7687
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=speakup_dev

# ── OpenAI ──
OPENAI_API_KEY=sk-your-key
OPENAI_MODEL=gpt-4o
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# ── Anthropic ──
ANTHROPIC_API_KEY=sk-ant-your-key
ANTHROPIC_MODEL=claude-sonnet-4-20250514

# ── Google Gemini ──
GEMINI_API_KEY=AIza-your-key
GEMINI_MODEL=gemini-2.5-flash
GEMINI_PRO_MODEL=gemini-2.5-pro

# ── HuggingFace ──
HUGGINGFACE_API_KEY=hf_your-key
HUGGINGFACE_MODEL=meta-llama/Llama-3.3-70B-Instruct

# ── OpenRouter (fallback gateway — access all LLMs) ──
OPENROUTER_API_KEY=sk-or-your-key
OPENROUTER_DEFAULT_MODEL=openai/gpt-4o

# ── LLM Routing ──
LLM_FALLBACK_ENABLED=true
LLM_CIRCUIT_BREAKER_THRESHOLD=3
LLM_CIRCUIT_BREAKER_TIMEOUT=30

# ── LangSmith ──
LANGCHAIN_TRACING_V2=true
LANGCHAIN_API_KEY=
LANGCHAIN_PROJECT=speakup-ai

# ── MCP Tool Integrations ──

# Slack
SLACK_BOT_TOKEN=xoxb-your-bot-token
SLACK_USER_TOKEN=xoxp-your-user-token
SLACK_DEFAULT_CHANNEL=

# Google (Gmail + Calendar — OAuth2)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_ACCESS_TOKEN=
GOOGLE_REFRESH_TOKEN=

# SMTP fallback for email
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=

# GitHub
GITHUB_TOKEN=ghp_your-token
GITHUB_DEFAULT_OWNER=
GITHUB_DEFAULT_REPO=

# Jira
JIRA_BASE_URL=https://your-org.atlassian.net
JIRA_EMAIL=
JIRA_API_TOKEN=
JIRA_DEFAULT_PROJECT=

# Linear
LINEAR_API_KEY=lin_api_your-key
LINEAR_DEFAULT_TEAM_ID=

# Notion
NOTION_API_KEY=ntn_your-key

# Tavily (web search)
TAVILY_API_KEY=tvly-your-key

# Salesforce CRM
SALESFORCE_INSTANCE_URL=https://your-org.salesforce.com
SALESFORCE_ACCESS_TOKEN=

# Twitter / X
TWITTER_BEARER_TOKEN=

# Microsoft Graph (Teams + Outlook)
MICROSOFT_GRAPH_TOKEN=

# ── OpenClaw (browser automation + workflows) ──
OPENCLAW_URL=http://localhost:3100
OPENCLAW_API_KEY=

# ── LiveKit (read-only, for audio stream ingestion) ──
LIVEKIT_HOST=http://localhost:7880
LIVEKIT_API_KEY=devkey
LIVEKIT_API_SECRET=secret

# ── Sentry ──
SENTRY_DSN=

# ── Express Backend (upstream) ──
EXPRESS_BACKEND_URL=http://localhost:5000
EXPRESS_INTERNAL_API_KEY=change-me-shared-secret

# ── Celery ──
CELERY_BROKER_URL=redis://localhost:6379/2
CELERY_RESULT_BACKEND=redis://localhost:6379/3

# ── Model Paths (local inference) ──
WHISPER_MODEL_SIZE=base
WHISPER_DEVICE=cpu
WHISPER_COMPUTE_TYPE=int8
MEDIAPIPE_MODEL_PATH=./models/mediapipe
